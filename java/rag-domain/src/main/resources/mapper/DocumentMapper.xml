<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="steveluxor.ragknowledgesystem.mapper.DocumentMapper">

    <insert id="insert" parameterType="steveluxor.ragknowledgesystem.entity.Document" useGeneratedKeys="true" keyProperty="id">
        insert into document
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="userId != null">user_id,</if>
            <if test="fileName != null">file_name,</if>
            <if test="filePath != null">file_path,</if>
            <if test="fileSize != null">file_size,</if>
            <if test="fileType != null">file_type,</if>
            <if test="status != null">status,</if>
            <if test="permission != null">permission,</if>
            <if test="createUser != null">create_user,</if>
            <if test="updateUser != null">update_user,</if>
            create_time,
            update_time,
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="userId != null">#{userId},</if>
            <if test="fileName != null">#{fileName},</if>
            <if test="filePath != null">#{filePath},</if>
            <if test="fileSize != null">#{fileSize},</if>
            <if test="fileType != null">#{fileType},</if>
            <if test="status != null">#{status},</if>
            <if test="permission != null">#{permission},</if>
            <if test="createUser != null">#{createUser},</if>
            <if test="updateUser != null">#{updateUser},</if>
            #{createTime},
            #{updateTime},
        </trim>
    </insert>

    <select id="selectById" resultType="steveluxor.ragknowledgesystem.entity.Document">
        select * from document where id = #{id}
    </select>

    <delete id="deleteById">
        delete from document where id = #{id}
    </delete>

    <select id="selectByUserId" resultType="steveluxor.ragknowledgesystem.entity.Document">
        select * from document
        where user_id = #{userId} or permission = 0
        order by create_time desc
    </select>

    <update id="updateStatus">
        update document set status = #{status} where id = #{id}
    </update>

    <update id="updateDocument" parameterType="steveluxor.ragknowledgesystem.entity.Document">
        update document
        <trim prefix="SET" suffixOverrides=",">
            <if test="fileName != null">file_name = #{fileName},</if>
            <if test="filePath != null">file_path = #{filePath},</if>
            <if test="fileSize != null">file_size = #{fileSize},</if>
            <if test="fileType != null">file_type = #{fileType},</if>
            <if test="status != null">status = #{status},</if>
            <if test="permission != null">permission = #{permission},</if>
            update_time = NOW()
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteByUserId">
        delete from document where user_id = #{userId}
    </delete>

    <select id="selectOwnByUserId" resultType="steveluxor.ragknowledgesystem.entity.Document">
        select * from document where user_id = #{userId} order by create_time desc
    </select>

    <select id="selectByFileName" resultType="steveluxor.ragknowledgesystem.entity.Document">
        select * from document where file_name = #{fileName} order by create_time desc
    </select>

</mapper>
